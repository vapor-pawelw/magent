    "permissionsDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Control how agents handle permissions and sandboxing. Only applies to Claude and Codex."
          }
        }
      }
    },
    "permissionsEnableSandbox": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable sandbox"
          }
        }
      }
    },
    "permissionsEnableSandboxDescriptionOnboarding": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restrict agent filesystem access to the workspace. Codex uses --full-auto."
          }
        }
      }
    },
    "permissionsEnableSandboxDescriptionSettings": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restrict agent filesystem access to the workspace. Codex uses --full-auto. Only applies to Codex (Claude sandboxes by default when permissions are not skipped)."
          }
        }
      }
    },
    "permissionsFullDiskAccessDescriptionLong": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Full Disk Access to Magent so agents can read and modify files outside the workspace (e.g. ~/.zshrc, ~/Library). Useful when agents need to inspect shell configs, install tools, or access protected directories. Without it, macOS may silently block file access."
          }
        }
      }
    },
    "permissionsFullDiskAccessDescriptionShort": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Full Disk Access so agents can read and modify files outside the workspace (e.g. ~/.zshrc, ~/Library)."
          }
        }
      }
    },
    "permissionsFullDiskAccessGranted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ Granted"
          }
        }
      }
    },
    "permissionsFullDiskAccessNotGranted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "❌ Not Granted"
