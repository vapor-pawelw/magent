    "permissionsSkipPromptsDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Agents run without asking for approval. Claude uses --dangerously-skip-permissions, Codex uses --yolo."
          }
        }
      }
    },
